#!/bin/bash
# collab — CLI management tool for collab-runtime servers
# Installed to /usr/local/bin/collab by install.sh
#
# Usage:
#   collab logs [--detail]
#   collab status
#   collab doctor
#   collab update --check
#   collab update --apply
#   collab update
set -euo pipefail

COLLAB_LOG_DIR="/var/log/collab"
SUMMARY_LOG="${COLLAB_LOG_DIR}/install-summary.log"
DETAIL_LOG="${COLLAB_LOG_DIR}/install-detail.log"

# Persistent test database created by scripts/04-install-timescaledb.sh.
# Keep this literal identical to TEST_DB in that script.
TEST_DB="collab_test"

# ── Colour helpers ─────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  C_RESET='\033[0m'
  C_OK='\033[0;32m'
  C_WARN='\033[0;33m'
  C_ERROR='\033[0;31m'
  C_BOLD='\033[1m'
  C_DIM='\033[2m'
  C_CYAN='\033[0;36m'
else
  C_RESET='' C_OK='' C_WARN='' C_ERROR='' C_BOLD='' C_DIM='' C_CYAN=''
fi

pass()  { echo -e "  ${C_OK}PASS${C_RESET}  $*"; }
fail()  { echo -e "  ${C_ERROR}FAIL${C_RESET}  $*"; }
info()  { echo -e "  ${C_CYAN}INFO${C_RESET}  $*"; }
warn()  { echo -e "  ${C_WARN}WARN${C_RESET}  $*"; }
divider(){ echo -e "${C_DIM}────────────────────────────────────────────────────────${C_RESET}"; }
header(){ echo -e "\n${C_BOLD}$*${C_RESET}"; divider; }

# ── Subcommand: logs ───────────────────────────────────────────────────────────
cmd_logs() {
  local detail=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --detail) detail=true ;;
      *) echo "Unknown option: $1. Usage: collab logs [--detail]" >&2; exit 1 ;;
    esac
    shift
  done

  if [[ "$detail" == true ]]; then
    local target="$DETAIL_LOG"
    header "collab — install detail log (last 50 lines)"
  else
    local target="$SUMMARY_LOG"
    header "collab — install summary log (last 50 lines)"
  fi

  if [[ ! -f "$target" ]]; then
    warn "Log file not found: ${target}"
    warn "Has install.sh been run on this server?"
    exit 0
  fi

  tail -n 50 "$target"
  echo ""
  info "Full log: ${target}"
}

# ── Subcommand: status ─────────────────────────────────────────────────────────
cmd_status() {
  header "collab — server status"

  # Service status
  echo -e "\n${C_BOLD}Services${C_RESET}"
  divider
  for svc in nginx postgresql redis-server; do
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
      pass "${svc}"
    else
      fail "${svc} (not active)"
    fi
  done

  # Component versions
  echo -e "\n${C_BOLD}Versions${C_RESET}"
  divider
  command -v nginx     &>/dev/null && info "nginx      $(nginx -v 2>&1 | sed 's/nginx version: //')"
  command -v psql      &>/dev/null && info "postgresql $(psql --version)"
  command -v redis-cli &>/dev/null && info "redis      $(redis-server --version)"
  command -v node      &>/dev/null && info "node       $(node --version)"
  command -v npm       &>/dev/null && info "npm        $(npm --version)"
  command -v pm2       &>/dev/null && info "pm2        $(pm2 --version 2>/dev/null)"
  command -v 7z        &>/dev/null && info "7zip       $(7z i 2>&1 | grep '7-Zip' | head -1 | awk '{print $1, $2}')"

  # Test database (TimescaleDB health-check DB)
  echo -e "\n${C_BOLD}Database${C_RESET}"
  divider
  if command -v psql &>/dev/null && systemctl is-active --quiet postgresql 2>/dev/null; then
    if sudo -u postgres psql -Atqc \
         "SELECT 1 FROM pg_database WHERE datname = '${TEST_DB}';" 2>/dev/null | grep -q 1; then
      tsdb_ver="$(sudo -u postgres psql -Atqc -d "$TEST_DB" \
        "SELECT extversion FROM pg_extension WHERE extname = 'timescaledb';" 2>/dev/null || true)"
      rows="$(sudo -u postgres psql -Atqc -d "$TEST_DB" \
        "SELECT count(*) FROM collab_healthcheck;" 2>/dev/null || true)"
      if [[ -n "$tsdb_ver" ]]; then
        pass "${TEST_DB} (timescaledb ${tsdb_ver}, healthcheck rows: ${rows:-?})"
      else
        warn "${TEST_DB} exists but timescaledb extension not enabled"
      fi
    else
      warn "${TEST_DB} not found (run install.sh / step 04 to create it)"
    fi
  else
    warn "postgresql not running — skipping database check"
  fi

  # Disk usage
  echo -e "\n${C_BOLD}Disk usage${C_RESET}"
  divider

  printf "  %-12s %8s %8s %8s %6s\n" "Mounted" "Size" "Used" "Avail" "Use%"
  df -h / /data 2>/dev/null | tail -n +2 | \
    awk '{printf "  %-12s %8s %8s %8s %6s\n", $1, $2, $3, $4, $5}'

  echo ""
}

# ── Subcommand: doctor ────────────────────────────────────────────────────────
cmd_doctor() {
  header "collab — doctor"
  local failures=0

  # ── Services ────────────────────────────────────────────────────────────────
  echo -e "\n${C_BOLD}Service health${C_RESET}"
  divider

  for svc in nginx postgresql redis-server; do
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
      pass "${svc} is active"
    else
      fail "${svc} is NOT active"
      (( failures++ )) || true
    fi
  done

  # ── Node.js version ≥ 24 ────────────────────────────────────────────────────
  echo -e "\n${C_BOLD}Node.js${C_RESET}"
  divider

  if command -v node &>/dev/null; then
    NODE_MAJOR="$(node --version | sed 's/v//' | cut -d. -f1)"
    if (( NODE_MAJOR >= 24 )); then
      pass "Node.js $(node --version) (major ${NODE_MAJOR} >= 24)"
    else
      fail "Node.js $(node --version) — major version ${NODE_MAJOR} is below required 24"
      (( failures++ )) || true
    fi
  else
    fail "Node.js not found"
    (( failures++ )) || true
  fi

  # ── npm ──────────────────────────────────────────────────────────────────────
  if command -v npm &>/dev/null; then
    pass "npm $(npm --version) found"
  else
    fail "npm not found"
    (( failures++ )) || true
  fi

  # ── PM2 ──────────────────────────────────────────────────────────────────────
  echo -e "\n${C_BOLD}PM2${C_RESET}"
  divider

  if command -v pm2 &>/dev/null; then
    pass "pm2 $(pm2 --version 2>/dev/null) found"
  else
    fail "pm2 not found"
    (( failures++ )) || true
  fi

  # Check if pm2 systemd unit exists
  if systemctl list-unit-files --type=service 2>/dev/null | grep -q "^pm2"; then
    pass "pm2 systemd unit registered"
  else
    warn "pm2 systemd unit not found (run: pm2 startup systemd)"
  fi

  # ── PostgreSQL + TimescaleDB extension ───────────────────────────────────────
  echo -e "\n${C_BOLD}PostgreSQL + TimescaleDB${C_RESET}"
  divider

  if command -v psql &>/dev/null && systemctl is-active --quiet postgresql 2>/dev/null; then
    TSDB_VER="$(sudo -u postgres psql -Atqc -d "$TEST_DB" \
      "SELECT extversion FROM pg_extension WHERE extname = 'timescaledb';" \
      2>/dev/null || true)"
    if [[ -n "$TSDB_VER" ]]; then
      pass "TimescaleDB extension installed in ${TEST_DB} (version ${TSDB_VER})"
    else
      fail "TimescaleDB extension NOT found in ${TEST_DB} (run install.sh step 04, or: sudo -u postgres psql -d ${TEST_DB} -c 'CREATE EXTENSION IF NOT EXISTS timescaledb;')"
      (( failures++ )) || true
    fi

    PG_VER="$(psql --version | awk '{print $3}')"
    pass "PostgreSQL ${PG_VER}"
  else
    fail "PostgreSQL not running or psql not found — skipping TimescaleDB check"
    (( failures++ )) || true
  fi

  # ── Logs directory ────────────────────────────────────────────────────────────
  echo -e "\n${C_BOLD}Logs${C_RESET}"
  divider

  for f in "$SUMMARY_LOG" "$DETAIL_LOG"; do
    if [[ -f "$f" ]]; then
      pass "$(basename "$f") exists"
    else
      warn "$(basename "$f") not found (install may not have run yet)"
    fi
  done

  # ── Final verdict ─────────────────────────────────────────────────────────────
  echo ""
  divider
  if (( failures == 0 )); then
    echo -e "  ${C_OK}${C_BOLD}All checks passed.${C_RESET}"
  else
    echo -e "  ${C_ERROR}${C_BOLD}${failures} check(s) failed.${C_RESET} Review the output above."
  fi
  echo ""

  return $failures
}

# ── Subcommand: update ─────────────────────────────────────────────────────────
cmd_update() {
  local mode="${1:-}"

  case "$mode" in
    --check)
      header "collab — update check (dry-run)"
      info "Running apt-get upgrade simulation…"
      echo ""
      apt-get -s upgrade 2>&1 | grep -E "^(Inst|Remv|[0-9])" || \
        echo "  No upgrades available."
      echo ""
      ;;
    --apply)
      if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
        echo "[ERR]  'collab update --apply' must be run as root. Use: sudo collab update --apply" >&2
        exit 1
      fi
      header "collab — applying system updates"
      apt-get update -y
      DEBIAN_FRONTEND=noninteractive apt-get upgrade -y
      apt-get autoremove -y
      apt-get clean
      echo ""
      info "System update complete."
      ;;
    "")
      echo ""
      echo -e "${C_BOLD}collab update${C_RESET} — requires a flag:"
      echo ""
      echo "  collab update --check    Show available apt upgrades (dry-run, no changes)"
      echo "  collab update --apply    Download and install all available apt upgrades"
      echo ""
      exit 0
      ;;
    *)
      echo "Unknown option: ${mode}" >&2
      echo "Usage: collab update --check | --apply" >&2
      exit 1
      ;;
  esac
}

# ── Usage / help ───────────────────────────────────────────────────────────────
cmd_help() {
  echo ""
  echo -e "${C_BOLD}collab${C_RESET} — collab-runtime server management CLI"
  echo ""
  echo "Usage: collab <command> [options]"
  echo ""
  echo "Commands:"
  echo "  logs [--detail]     Show install log (summary or full detail)"
  echo "  status              Show service health, versions, and disk usage"
  echo "  doctor              Run PASS/FAIL diagnostics for all components"
  echo "  update --check      List available apt upgrades (dry-run)"
  echo "  update --apply      Apply all apt upgrades (requires sudo)"
  echo "  help                Show this help message"
  echo ""
  echo "Examples:"
  echo "  collab status"
  echo "  collab doctor"
  echo "  collab logs --detail"
  echo "  collab update --check"
  echo "  sudo collab update --apply"
  echo ""
}

# ── Dispatch ───────────────────────────────────────────────────────────────────
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  logs)    cmd_logs   "$@" ;;
  status)  cmd_status "$@" ;;
  doctor)  cmd_doctor "$@" ;;
  update)  cmd_update "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    echo "Unknown command: ${COMMAND}" >&2
    echo "Run 'collab help' for usage." >&2
    exit 1
    ;;
esac
