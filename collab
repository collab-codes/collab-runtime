#!/bin/bash
# collab — CLI management tool for collab-runtime servers
# Installed to /usr/local/bin/collab by install.sh
#
# Usage:
#   collab logs [--detail]
#   collab status
#   collab statusdb
#   collab doctor
#   collab update --check
#   collab update --apply
#   collab update
set -euo pipefail

COLLAB_LOG_DIR="/var/log/collab"
SUMMARY_LOG="${COLLAB_LOG_DIR}/install-summary.log"
DETAIL_LOG="${COLLAB_LOG_DIR}/install-detail.log"

# Persistent test database created by scripts/04-install-timescaledb.sh.
# Keep this literal identical to TEST_DB in that script.
TEST_DB="collab_test"

# ── Colour helpers ─────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  C_RESET='\033[0m'
  C_OK='\033[0;32m'
  C_WARN='\033[0;33m'
  C_ERROR='\033[0;31m'
  C_BOLD='\033[1m'
  C_DIM='\033[2m'
  C_CYAN='\033[0;36m'
else
  C_RESET='' C_OK='' C_WARN='' C_ERROR='' C_BOLD='' C_DIM='' C_CYAN=''
fi

pass()  { echo -e "  ${C_OK}PASS${C_RESET}  $*"; }
fail()  { echo -e "  ${C_ERROR}FAIL${C_RESET}  $*"; }
info()  { echo -e "  ${C_CYAN}INFO${C_RESET}  $*"; }
warn()  { echo -e "  ${C_WARN}WARN${C_RESET}  $*"; }
divider(){ echo -e "${C_DIM}────────────────────────────────────────────────────────${C_RESET}"; }
header(){ echo -e "\n${C_BOLD}$*${C_RESET}"; divider; }

# ── Subcommand: logs ───────────────────────────────────────────────────────────
cmd_logs() {
  local detail=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --detail) detail=true ;;
      *) echo "Unknown option: $1. Usage: collab logs [--detail]" >&2; exit 1 ;;
    esac
    shift
  done

  if [[ "$detail" == true ]]; then
    local target="$DETAIL_LOG"
    header "collab — install detail log (last 50 lines)"
  else
    local target="$SUMMARY_LOG"
    header "collab — install summary log (last 50 lines)"
  fi

  if [[ ! -f "$target" ]]; then
    warn "Log file not found: ${target}"
    warn "Has install.sh been run on this server?"
    exit 0
  fi

  tail -n 50 "$target"
  echo ""
  info "Full log: ${target}"
}

# ── Subcommand: status ─────────────────────────────────────────────────────────
cmd_status() {
  header "collab — server status"

  # Service status
  echo -e "\n${C_BOLD}Services${C_RESET}"
  divider
  for svc in nginx postgresql redis-server collab-sites-agent; do
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
      pass "${svc}"
    else
      fail "${svc} (not active)"
    fi
  done

  # Component versions
  echo -e "\n${C_BOLD}Versions${C_RESET}"
  divider
  command -v nginx     &>/dev/null && info "nginx      $(nginx -v 2>&1 | sed 's/nginx version: //')"
  command -v psql      &>/dev/null && info "postgresql $(psql --version)"
  command -v redis-cli &>/dev/null && info "redis      $(redis-server --version)"
  command -v node      &>/dev/null && info "node       $(node --version)"
  command -v npm       &>/dev/null && info "npm        $(npm --version)"
  command -v pm2       &>/dev/null && info "pm2        $(pm2 --version 2>/dev/null)"
  command -v 7z        &>/dev/null && info "7zip       $(7z i 2>&1 | grep '7-Zip' | head -1 | awk '{print $1, $2}')"
  command -v certbot   &>/dev/null && info "certbot    $(certbot --version 2>&1 | awk '{print $2}')"

  # Test database (TimescaleDB health-check DB)
  echo -e "\n${C_BOLD}Database${C_RESET}"
  divider
  if command -v psql &>/dev/null && systemctl is-active --quiet postgresql 2>/dev/null; then
    if sudo -u postgres psql -Atqc \
         "SELECT 1 FROM pg_database WHERE datname = '${TEST_DB}';" 2>/dev/null | grep -q 1; then
      tsdb_ver="$(sudo -u postgres psql -Atq -d "$TEST_DB" -c \
        "SELECT extversion FROM pg_extension WHERE extname = 'timescaledb';" 2>/dev/null || true)"
      rows="$(sudo -u postgres psql -Atq -d "$TEST_DB" -c \
        "SELECT count(*) FROM collab_healthcheck;" 2>/dev/null || true)"
      if [[ -n "$tsdb_ver" ]]; then
        pass "${TEST_DB} (timescaledb ${tsdb_ver}, healthcheck rows: ${rows:-?})"
      else
        warn "${TEST_DB} exists but timescaledb extension not enabled"
      fi
    else
      warn "${TEST_DB} not found (run install.sh / step 04 to create it)"
    fi
  else
    warn "postgresql not running — skipping database check"
  fi

  # Disk usage
  echo -e "\n${C_BOLD}Disk usage${C_RESET}"
  divider

  printf "  %-12s %8s %8s %8s %6s\n" "Mounted" "Size" "Used" "Avail" "Use%"
  df -h / /data 2>/dev/null | tail -n +2 | \
    awk '{printf "  %-12s %8s %8s %8s %6s\n", $1, $2, $3, $4, $5}'

  echo ""
}

# ── Subcommand: statusdb ─────────────────────────────────────────────────────
# Lists every database owned by the 'collab' role and the tables inside each.
# Connects as the 'collab' PostgreSQL user over TCP. The password is NEVER stored
# in this script: it is read interactively at runtime (or taken from $PGPASSWORD
# if it is already exported in the environment).
cmd_statusdb() {
  local db_user="collab"
  local db_host="${PGHOST:-localhost}"
  local db_port="${PGPORT:-5432}"

  header "collab — databases (user: ${db_user}@${db_host}:${db_port})"

  if ! command -v psql &>/dev/null; then
    fail "psql not found"
    exit 1
  fi
  if ! systemctl is-active --quiet postgresql 2>/dev/null; then
    warn "postgresql service is not active — trying to connect anyway"
  fi

  # Password: taken from the environment if present, otherwise prompted (never
  # hard-coded in source). Read silently so it is not echoed to the terminal.
  local pw="${PGPASSWORD:-}"
  if [[ -z "$pw" ]]; then
    read -rsp "  Password for PostgreSQL role '${db_user}': " pw
    echo ""
  fi
  export PGPASSWORD="$pw"

  # psql helper bound to this connection (-X: ignore ~/.psqlrc, -A -t -q: script-friendly).
  psql_collab() { psql -h "$db_host" -p "$db_port" -U "$db_user" -X -Atq "$@"; }

  # Connection / auth test before doing anything else.
  if ! psql_collab -d postgres -c "SELECT 1" &>/dev/null; then
    unset PGPASSWORD
    fail "could not connect as '${db_user}' (wrong password, or role/permission issue)"
    exit 1
  fi

  # Databases owned by the collab role.
  local dbs
  dbs="$(psql_collab -d postgres -c \
    "SELECT d.datname FROM pg_database d JOIN pg_roles r ON d.datdba = r.oid \
     WHERE r.rolname = '${db_user}' AND NOT d.datistemplate ORDER BY d.datname")"

  if [[ -z "$dbs" ]]; then
    unset PGPASSWORD
    warn "no databases owned by role '${db_user}'"
    echo ""
    return 0
  fi

  # User tables with on-disk size and estimated row count.
  # TimescaleDB internal chunk/catalog schemas are hidden for readability.
  local tbl_query="\
    SELECT n.nspname || '.' || c.relname, \
           pg_size_pretty(pg_total_relation_size(c.oid)), \
           COALESCE(s.n_live_tup, 0) \
    FROM pg_class c \
    JOIN pg_namespace n ON n.oid = c.relnamespace \
    LEFT JOIN pg_stat_user_tables s ON s.relid = c.oid \
    WHERE c.relkind IN ('r','p') \
      AND n.nspname NOT IN ('pg_catalog','information_schema','timescaledb_information') \
      AND n.nspname NOT LIKE 'pg_toast%' \
      AND n.nspname NOT LIKE '_timescaledb%' \
    ORDER BY 1"

  local db dbsize tbl size rows count
  while IFS= read -r db; do
    [[ -z "$db" ]] && continue
    dbsize="$(psql_collab -d "$db" -c "SELECT pg_size_pretty(pg_database_size('${db}'))" 2>/dev/null || echo '?')"
    echo -e "\n${C_BOLD}${db}${C_RESET} ${C_DIM}(${dbsize})${C_RESET}"
    divider
    printf "  %-44s %10s %12s\n" "Table" "Size" "Est.rows"
    count=0
    while IFS='|' read -r tbl size rows; do
      [[ -z "$tbl" ]] && continue
      printf "  %-44s %10s %12s\n" "$tbl" "$size" "$rows"
      count=$((count + 1))
    done < <(psql_collab -d "$db" -c "$tbl_query" 2>/dev/null || true)
    [[ "$count" -eq 0 ]] && echo -e "  ${C_DIM}(no user tables)${C_RESET}"
  done <<< "$dbs"

  unset PGPASSWORD
  echo ""
}

# ── Subcommand: doctor ────────────────────────────────────────────────────────
cmd_doctor() {
  header "collab — doctor"
  local failures=0

  # ── Services ────────────────────────────────────────────────────────────────
  echo -e "\n${C_BOLD}Service health${C_RESET}"
  divider

  for svc in nginx postgresql redis-server; do
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
      pass "${svc} is active"
    else
      fail "${svc} is NOT active"
      (( failures++ )) || true
    fi
  done

  # ── Node.js version ≥ 24 ────────────────────────────────────────────────────
  echo -e "\n${C_BOLD}Node.js${C_RESET}"
  divider

  if command -v node &>/dev/null; then
    NODE_MAJOR="$(node --version | sed 's/v//' | cut -d. -f1)"
    if (( NODE_MAJOR >= 24 )); then
      pass "Node.js $(node --version) (major ${NODE_MAJOR} >= 24)"
    else
      fail "Node.js $(node --version) — major version ${NODE_MAJOR} is below required 24"
      (( failures++ )) || true
    fi
  else
    fail "Node.js not found"
    (( failures++ )) || true
  fi

  # ── npm ──────────────────────────────────────────────────────────────────────
  if command -v npm &>/dev/null; then
    pass "npm $(npm --version) found"
  else
    fail "npm not found"
    (( failures++ )) || true
  fi

  # ── PM2 ──────────────────────────────────────────────────────────────────────
  echo -e "\n${C_BOLD}PM2${C_RESET}"
  divider

  if command -v pm2 &>/dev/null; then
    pass "pm2 $(pm2 --version 2>/dev/null) found"
  else
    fail "pm2 not found"
    (( failures++ )) || true
  fi

  # Check if pm2 systemd unit exists
  if systemctl list-unit-files --type=service 2>/dev/null | grep -q "^pm2"; then
    pass "pm2 systemd unit registered"
  else
    warn "pm2 systemd unit not found (run: pm2 startup systemd)"
  fi

  # ── PostgreSQL + TimescaleDB extension ───────────────────────────────────────
  echo -e "\n${C_BOLD}PostgreSQL + TimescaleDB${C_RESET}"
  divider

  if command -v psql &>/dev/null && systemctl is-active --quiet postgresql 2>/dev/null; then
    TSDB_VER="$(sudo -u postgres psql -Atq -d "$TEST_DB" -c \
      "SELECT extversion FROM pg_extension WHERE extname = 'timescaledb';" \
      2>/dev/null || true)"
    if [[ -n "$TSDB_VER" ]]; then
      pass "TimescaleDB extension installed in ${TEST_DB} (version ${TSDB_VER})"
    else
      fail "TimescaleDB extension NOT found in ${TEST_DB} (run install.sh step 04, or: sudo -u postgres psql -d ${TEST_DB} -c 'CREATE EXTENSION IF NOT EXISTS timescaledb;')"
      (( failures++ )) || true
    fi

    PG_VER="$(psql --version | awk '{print $3}')"
    pass "PostgreSQL ${PG_VER}"
  else
    fail "PostgreSQL not running or psql not found — skipping TimescaleDB check"
    (( failures++ )) || true
  fi

  # ── Logs directory ────────────────────────────────────────────────────────────
  echo -e "\n${C_BOLD}Logs${C_RESET}"
  divider

  for f in "$SUMMARY_LOG" "$DETAIL_LOG"; do
    if [[ -f "$f" ]]; then
      pass "$(basename "$f") exists"
    else
      warn "$(basename "$f") not found (install may not have run yet)"
    fi
  done

  # ── Final verdict ─────────────────────────────────────────────────────────────
  echo ""
  divider
  if (( failures == 0 )); then
    echo -e "  ${C_OK}${C_BOLD}All checks passed.${C_RESET}"
  else
    echo -e "  ${C_ERROR}${C_BOLD}${failures} check(s) failed.${C_RESET} Review the output above."
  fi
  echo ""

  return $failures
}

# ── Subcommand: update ─────────────────────────────────────────────────────────
cmd_update() {
  local mode="${1:-}"

  case "$mode" in
    --check)
      header "collab — update check (dry-run)"
      info "Running apt-get upgrade simulation…"
      echo ""
      apt-get -s upgrade 2>&1 | grep -E "^(Inst|Remv|[0-9])" || \
        echo "  No upgrades available."
      echo ""
      ;;
    --apply)
      if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
        echo "[ERR]  'collab update --apply' must be run as root. Use: sudo collab update --apply" >&2
        exit 1
      fi
      header "collab — applying system updates"
      apt-get update -y
      DEBIAN_FRONTEND=noninteractive apt-get upgrade -y
      apt-get autoremove -y
      apt-get clean
      echo ""
      info "System update complete."
      ;;
    "")
      echo ""
      echo -e "${C_BOLD}collab update${C_RESET} — requires a flag:"
      echo ""
      echo "  collab update --check    Show available apt upgrades (dry-run, no changes)"
      echo "  collab update --apply    Download and install all available apt upgrades"
      echo ""
      exit 0
      ;;
    *)
      echo "Unknown option: ${mode}" >&2
      echo "Usage: collab update --check | --apply" >&2
      exit 1
      ;;
  esac
}

# ── Subcommand: msg ────────────────────────────────────────────────────────────
# Manages the collab-messages app (pm2 'msg'), installed by scripts/11-install-
# collab-messages.sh, which copies itself to /usr/local/lib/collab/.
cmd_msg() {
  local mode="${1:-}"
  local installer="/usr/local/lib/collab/install-collab-messages.sh"

  case "$mode" in
    update)
      shift
      if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
        echo "[ERR]  'collab msg update' must be run as root. Use: sudo collab msg update" >&2
        exit 1
      fi
      if [[ ! -f "$installer" ]]; then
        echo "[ERR]  Installer not found: ${installer}" >&2
        echo "[ERR]  Run collab-runtime's scripts/11-install-collab-messages.sh once (or install.sh)." >&2
        exit 1
      fi
      header "collab — updating collab-messages"
      bash "$installer" "$@"
      ;;
    status)
      header "collab — collab-messages status"
      local version_file="/data/msg.collab.codes/node/collab-messages.version"
      if [[ -f "$version_file" ]]; then
        info "installed version: $(cat "$version_file")"
      else
        warn "no installed version recorded (${version_file} not found)"
      fi
      if command -v pm2 &>/dev/null; then
        pm2 ls | grep -E "msg|─" || true
      else
        warn "pm2 not found"
      fi
      echo ""
      ;;
    "")
      echo ""
      echo -e "${C_BOLD}collab msg${C_RESET} — requires a subcommand:"
      echo ""
      echo "  collab msg update [--force]   Install/update collab-messages from S3 (requires sudo)"
      echo "  collab msg status             Show installed version and pm2 state"
      echo ""
      exit 0
      ;;
    *)
      echo "Unknown option: ${mode}" >&2
      echo "Usage: collab msg update [--force] | collab msg status" >&2
      exit 1
      ;;
  esac
}

# ── Usage / help ───────────────────────────────────────────────────────────────
cmd_help() {
  echo ""
  echo -e "${C_BOLD}collab${C_RESET} — collab-runtime server management CLI"
  echo ""
  echo "Usage: collab <command> [options]"
  echo ""
  echo "Commands:"
  echo "  logs [--detail]     Show install log (summary or full detail)"
  echo "  status              Show service health, versions, and disk usage"
  echo "  statusdb            List all databases and tables owned by the 'collab' user"
  echo "  doctor              Run PASS/FAIL diagnostics for all components"
  echo "  update --check      List available apt upgrades (dry-run)"
  echo "  update --apply      Apply all apt upgrades (requires sudo)"
  echo "  msg update [--force] Install/update collab-messages from S3 (requires sudo)"
  echo "  msg status          Show collab-messages version and pm2 state"
  echo "  help                Show this help message"
  echo ""
  echo "Examples:"
  echo "  collab status"
  echo "  collab statusdb"
  echo "  collab doctor"
  echo "  collab logs --detail"
  echo "  collab update --check"
  echo "  sudo collab update --apply"
  echo ""
}

# ── Dispatch ───────────────────────────────────────────────────────────────────
COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  logs)     cmd_logs     "$@" ;;
  status)   cmd_status   "$@" ;;
  statusdb) cmd_statusdb "$@" ;;
  doctor)   cmd_doctor   "$@" ;;
  update)  cmd_update "$@" ;;
  msg)      cmd_msg      "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    echo "Unknown command: ${COMMAND}" >&2
    echo "Run 'collab help' for usage." >&2
    exit 1
    ;;
esac
